# Environment Variables
# NEVER commit this file with real values

# QRL Zond Public Testnet via RPC Proxy (no local node required)
RPC_URL=https://rpc.pqlymarket.com/
CHAIN_ID=32382

# Deployer wallet (used by deploy & drain scripts)
# Derive hexseed from your 34-word QRL mnemonic
HEXSEED=your_hexseed_here

# Cloudflare Tunnel token (from Zero Trust dashboard)
CF_TUNNEL_TOKEN=your_tunnel_token_here

# Admin secret for protected API endpoints (authorize-creator, etc.)
# Generate: openssl rand -hex 32
ADMIN_SECRET=your_admin_secret_here
