pragma hyperion ^0.0.2;

/// @title IOracle - Common interface for Oracle and GovernanceOracle
/// @notice Both Oracle.hyp and GovernanceOracle.hyp implement this interface.
interface IOracle {
    enum Outcome { Unresolved, Yes, No, Invalid }

    function isResolved(uint256 marketId) external view returns (bool);
    function getOutcome(uint256 marketId) external view returns (Outcome);
}
