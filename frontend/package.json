{
  "name": "pqlymarket-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tsx watch src/server.ts\" \"tailwindcss -i ./public/css/input.css -o ./public/css/output.css --watch\"",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/css/output.css --minify",
    "build:ts": "tsc",
    "build": "npm run build:ts && npm run build:css",
    "start": "node dist/server.js",
    "public": "./start-public.sh",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@theqrl/web3": "^0.4.0",
    "better-sqlite3": "^12.8.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "express-ejs-layouts": "^2.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/node": "^22.15.3",
    "concurrently": "^9.1.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
