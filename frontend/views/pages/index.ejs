<%
  // Safety defaults in case variables are missing
  if (typeof multiOutcomeMarkets === 'undefined') var multiOutcomeMarkets = [];
  if (typeof markets === 'undefined') var markets = [];
  if (typeof featured === 'undefined') var featured = null;
  if (typeof noMarkets === 'undefined') var noMarkets = true;
%>
<!-- Featured Section (Bento Style) -->
<% if (featured) { %>
<% 
  // Parse question to separate title and option if it contains ": "
  let featuredTitle = featured.question;
  let featuredOption = "";
  if (featured.question.includes("?: ")) {
    const parts = featured.question.split("?: ");
    featuredTitle = parts[0] + "?";
    featuredOption = parts[1];
  } else if (featured.question.includes(": ")) {
    const parts = featured.question.split(": ");
    featuredTitle = parts[0];
    featuredOption = parts[1];
  }
%>
<section class="grid grid-cols-1 lg:grid-cols-12 gap-6">
  <!-- Featured Market Card -->
  <div class="lg:col-span-8 bg-surface-container-low p-8 rounded-none flex flex-col justify-between border-l-4 border-primary">
    <div>
      <div class="flex items-center gap-2 mb-4">
        <span class="bg-primary/10 text-primary px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase">Featured Market</span>
        <span class="text-on-surface-variant text-[10px] font-medium uppercase tracking-wider">Ends <%= featured.endDate %></span>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-on-surface tracking-tight leading-tight mb-8">
        <%- featuredTitle.replace(/\$(\d+)/g, '<span class="text-primary">$$$1</span>') %>
      </h1>
      <div class="flex flex-wrap gap-4">
        <button class="btn-yes bg-primary text-on-primary font-bold px-10 py-4 text-lg hover:bg-primary-container active:scale-95 transition-all" data-market-id="<%= featured.id %>">
          YES <%= featuredOption ? `(${featuredOption})` : '' %>
        </button>
        <button class="btn-no bg-surface-container-highest text-on-surface font-bold px-10 py-4 text-lg hover:bg-surface-bright active:scale-95 transition-all" data-market-id="<%= featured.id %>">
          NO <%= featuredOption ? `(${featuredOption})` : '' %>
        </button>
      </div>
    </div>
    <div class="mt-12 grid grid-cols-3 gap-8">
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Volume</p>
        <p class="text-xl font-bold text-on-surface"><%= featured.volume %></p>
      </div>
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Chance of Yes</p>
        <p class="text-xl font-bold text-primary"><%= featured.chanceOfYes %>%</p>
      </div>
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Total Bets</p>
        <p class="text-xl font-bold text-on-surface"><%= featured.totalBets %></p>
      </div>
    </div>
  </div>

  <!-- Price Trend Card -->
  <div class="lg:col-span-4 bg-surface-container p-6 flex flex-col">
    <h3 class="text-sm font-bold text-on-surface mb-6 uppercase tracking-wider"><%= priceTrend.label %></h3>
    <div class="flex-1 flex items-end justify-between gap-1 h-32">
      <% priceTrend.bars.forEach(function(bar) { %>
        <div class="w-full bg-primary rounded-t" style="height: <%= bar %>%; opacity: <%= 0.3 + (bar / 100) * 0.7 %>;"></div>
      <% }); %>
    </div>
    <div class="mt-6">
      <p class="text-[10px] text-on-surface-variant mb-1">CURRENT PRICE</p>
      <p class="text-2xl font-black text-on-surface"><%= priceTrend.currentPrice %></p>
      <p class="text-xs text-primary font-bold"><%= priceTrend.change24h %></p>
    </div>
  </div>
</section>
<% } else { %>
<section class="bg-surface-container-low p-12 border-l-4 border-outline-variant/20 text-center">
  <span class="material-symbols-outlined text-5xl text-on-surface-variant mb-4">signal_disconnected</span>
  <h2 class="text-2xl font-bold text-on-surface mb-2">No Markets Available</h2>
  <p class="text-on-surface-variant text-sm">No markets yet. Deploy contracts and create markets to see live predictions.</p>
</section>
<% } %>

<!-- Top Markets Section -->
<section>
  <div class="flex justify-between items-end mb-8">
    <div>
      <h2 class="text-2xl font-bold text-on-surface tracking-tighter uppercase">Top <%= activeCategory %> Markets</h2>
      <div class="h-1 w-12 bg-primary mt-2"></div>
    </div>
    <a class="text-xs font-bold text-primary hover:underline uppercase tracking-widest" href="/?category=<%= activeCategory %>">View All Markets</a>
  </div>

  <% if (multiOutcomeMarkets.length > 0 || markets.length > 0) { %>
  <div class="space-y-6" id="marketsGrid">

    <!-- Multi-Outcome Markets (Polymarket-style) -->
    <% multiOutcomeMarkets.forEach(function(m) { %>
      <a href="/market/<%= m.id %>" class="block bg-surface-container-low group hover:bg-surface-container-high transition-all p-6 border-l border-outline-variant/10">
        <div class="flex justify-between items-start mb-4">
          <div class="flex items-center gap-3">
            <span class="material-symbols-outlined text-primary text-2xl"><%= m.icon %></span>
            <div>
              <h4 class="text-lg font-bold text-on-surface leading-snug"><%= m.question %></h4>
              <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mt-1"><%= m.category %> &middot; <%= m.outcomeCount %> outcomes &middot; Ends <%= m.endDate %></p>
            </div>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="text-xs font-bold text-on-surface"><%= m.volume %></p>
            <p class="text-[10px] text-on-surface-variant">volume</p>
          </div>
        </div>
        <!-- Outcome rows preview (max 4) -->
        <div class="space-y-2 mt-4">
          <% m.outcomes.slice(0, 4).forEach(function(o) { %>
            <div class="flex items-center justify-between bg-surface-container py-2.5 px-4">
              <span class="text-sm text-on-surface font-medium flex-1"><%= o.label %></span>
              <div class="flex items-center gap-3">
                <span class="text-xs font-bold text-primary"><%= o.yesPrice %>%</span>
                <span class="bg-primary/10 text-primary text-[10px] font-bold px-3 py-1">Yes <%= o.yesPrice %>&cent;</span>
                <span class="bg-surface-container-highest text-on-surface-variant text-[10px] font-bold px-3 py-1">No <%= o.noPrice %>&cent;</span>
              </div>
            </div>
          <% }); %>
          <% if (m.outcomes.length > 4) { %>
            <p class="text-[10px] text-on-surface-variant text-center pt-1">+ <%= m.outcomes.length - 4 %> more outcomes</p>
          <% } %>
        </div>
      </a>
    <% }); %>

    <!-- Binary Markets -->
    <% if (markets.length > 0) { %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% markets.forEach(function(market) { %>
        <% 
          let marketTitle = market.question;
          let marketOption = "";
          if (market.question.includes("?: ")) {
            const parts = market.question.split("?: ");
            marketTitle = parts[0] + "?";
            marketOption = parts[1];
          } else if (market.question.includes(": ")) {
            const parts = market.question.split(": ");
            marketTitle = parts[0];
            marketOption = parts[1];
          }
        %>
        <a href="/market/<%= market.id %>" class="bg-surface-container-low group hover:bg-surface-container-high transition-all p-6 border-l border-outline-variant/10 block">
          <div class="flex justify-between items-start mb-6">
            <span class="material-symbols-outlined text-primary text-3xl"><%= market.icon || (market.category === 'BTC' ? 'currency_bitcoin' : 'shield') %></span>
            <div class="text-right">
              <p class="text-[10px] text-on-surface-variant font-bold"><%= market.category %></p>
            </div>
          </div>
          <h4 class="text-lg font-bold text-on-surface mb-6 leading-snug"><%= marketTitle %></h4>
          <div class="grid grid-cols-2 gap-4">
            <span class="bg-surface-container-highest flex flex-col items-center justify-center text-center text-[10px] font-black uppercase tracking-widest py-2 group-hover:text-primary transition-colors">
              <span class="text-on-surface-variant text-[8px] mb-0.5"><%= marketOption ? (marketOption.length > 10 ? marketOption.substring(0, 10)+'...' : marketOption) : 'YES' %></span>
              <span>Yes (<%= market.yesPrice %>&cent;)</span>
            </span>
            <span class="bg-surface-container-highest flex flex-col items-center justify-center text-center text-[10px] font-black uppercase tracking-widest py-2 group-hover:text-primary transition-colors">
              <span class="text-on-surface-variant text-[8px] mb-0.5"><%= marketOption ? (marketOption.length > 10 ? marketOption.substring(0, 10)+'...' : marketOption) : 'NO' %></span>
              <span>No (<%= market.noPrice %>&cent;)</span>
            </span>
          </div>
          <div class="mt-6 pt-6 border-t border-outline-variant/5 flex justify-between items-center">
            <span class="text-[10px] text-on-surface-variant uppercase tracking-tighter">Vol: <%= market.volume %></span>
            <span class="text-[10px] text-on-surface-variant uppercase tracking-tighter"><%= market.traders %> Traders</span>
          </div>
        </a>
      <% }); %>
    </div>
    <% } %>

  </div>
  <% } else { %>
  <div class="bg-surface-container-low p-8 text-center">
    <p class="text-on-surface-variant text-sm">No markets found for this category. Deploy contracts and create markets to get started.</p>
  </div>
  <% } %>
</section>

<!-- Data Visualization & Analytics Section -->
<section class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Volume Chart -->
  <div class="bg-surface-container-low p-8">
    <h3 class="text-sm font-bold text-on-surface mb-8 uppercase tracking-widest">Global Betting Volume 2026</h3>
    <div class="relative h-48 w-full">
      <canvas id="volumeChart"></canvas>
    </div>
    <div class="mt-6 flex justify-between items-center">
      <span class="text-[10px] font-medium text-on-surface-variant">MONTHLY GROWTH</span>
      <span class="text-primary font-bold"><%= volumeChart.monthlyGrowth %></span>
    </div>
  </div>

  <!-- Sentiment Index -->
  <div class="bg-surface-container-low p-8">
    <h3 class="text-sm font-bold text-on-surface mb-8 uppercase tracking-widest">Market Sentiment Index 2026</h3>
    <div class="flex items-center justify-between gap-4">
      <div class="flex-1">
        <div class="h-2 w-full bg-surface-container-highest overflow-hidden">
          <div class="h-full bg-primary" style="width: <%= sentiment.bullishPercent %>%"></div>
        </div>
        <div class="flex justify-between mt-2 text-[9px] text-on-surface-variant uppercase font-bold">
          <span>Bearish</span>
          <span class="text-primary"><%= sentiment.bullishPercent %>% Bullish</span>
          <span>Neutral</span>
        </div>
      </div>
      <div class="text-center">
        <div class="text-3xl font-black text-on-surface"><%= sentiment.signal %></div>
        <p class="text-[10px] text-primary tracking-widest uppercase">Strong Signal</p>
      </div>
    </div>
    <div class="mt-10 space-y-4">
      <div class="flex justify-between items-center">
        <span class="text-[10px] text-on-surface-variant">Active Positions</span>
        <span class="text-xs font-bold text-on-surface"><%= sentiment.activePositions %></span>
      </div>
      <div class="flex justify-between items-center">
        <span class="text-[10px] text-on-surface-variant">Open Interest</span>
        <span class="text-xs font-bold text-on-surface"><%= sentiment.openInterest %></span>
      </div>
    </div>
  </div>
</section>

<!-- Chart data for JS -->
<script>
  window.__VOLUME_CHART__ = <%- JSON.stringify(volumeChart) %>;
</script>
