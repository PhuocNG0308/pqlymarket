<!-- Market Detail Page -->
<section class="max-w-4xl mx-auto">
  <div class="mb-6">
    <a href="/?category=<%= market.category %>" class="text-xs text-on-surface-variant hover:text-primary transition-colors uppercase tracking-widest">
      &larr; Back to <%= market.category %> Markets
    </a>
  </div>

  <div class="bg-surface-container-low p-8 border-l-4 border-primary mb-8">
    <div class="flex items-center gap-2 mb-4">
      <span class="material-symbols-outlined text-primary text-3xl"><%= market.category === 'BTC' ? 'currency_bitcoin' : 'shield' %></span>
      <span class="bg-primary/10 text-primary px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase"><%= market.category %></span>
      <% if (market.resolved) { %>
        <span class="bg-error/10 text-error px-2 py-0.5 text-[10px] font-bold tracking-widest uppercase">Resolved</span>
      <% } else { %>
        <span class="text-on-surface-variant text-[10px] font-medium uppercase tracking-wider">Ends: <%= market.endDate %></span>
      <% } %>
    </div>

    <h1 class="text-3xl md:text-4xl font-extrabold text-on-surface tracking-tight leading-tight mb-8">
      <%= market.question %>
    </h1>

    <!-- Betting Panel -->
    <% if (!market.resolved) { %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-surface-container p-6">
          <h3 class="text-sm font-bold text-on-surface mb-4 uppercase tracking-wider">Buy YES</h3>
          <p class="text-3xl font-black text-primary mb-4"><%= market.yesPrice %>&cent;</p>
          <input type="number" id="yesAmount" placeholder="Amount (QRL)" min="0.001" step="0.001"
                 class="w-full bg-surface-container-highest text-on-surface text-sm px-4 py-3 mb-2 border-none focus:outline-none focus:ring-1 focus:ring-primary/20 placeholder:text-neutral-600" />
          <div class="flex justify-between text-[10px] text-on-surface-variant mb-1">
            <span>Est. shares: <span id="estYesShares" class="font-mono text-primary">—</span></span>
            <span>Avg. price: <span id="estYesAvgPrice" class="font-mono">—</span></span>
          </div>
          <p class="text-[10px] text-error mb-2 hidden" id="warnYesBuy"></p>
          <button class="btn-buy-yes w-full bg-primary text-on-primary font-bold py-3 hover:bg-primary-container active:scale-95 transition-all" data-market-id="<%= market.id %>">
            Buy YES Shares
          </button>
        </div>
        <div class="bg-surface-container p-6">
          <h3 class="text-sm font-bold text-on-surface mb-4 uppercase tracking-wider">Buy NO</h3>
          <p class="text-3xl font-black text-on-surface-variant mb-4"><%= market.noPrice %>&cent;</p>
          <input type="number" id="noAmount" placeholder="Amount (QRL)" min="0.001" step="0.001"
                 class="w-full bg-surface-container-highest text-on-surface text-sm px-4 py-3 mb-2 border-none focus:outline-none focus:ring-1 focus:ring-primary/20 placeholder:text-neutral-600" />
          <div class="flex justify-between text-[10px] text-on-surface-variant mb-1">
            <span>Est. shares: <span id="estNoShares" class="font-mono text-primary">—</span></span>
            <span>Avg. price: <span id="estNoAvgPrice" class="font-mono">—</span></span>
          </div>
          <p class="text-[10px] text-error mb-2 hidden" id="warnNoBuy"></p>
          <button class="btn-buy-no w-full bg-surface-container-highest text-on-surface font-bold py-3 hover:bg-surface-bright active:scale-95 transition-all" data-market-id="<%= market.id %>">
            Buy NO Shares
          </button>
        </div>
      </div>

      <!-- Sell Panel -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-surface-container p-6 border-l-2 border-error/30">
          <h3 class="text-sm font-bold text-on-surface mb-4 uppercase tracking-wider">Sell YES</h3>
          <p class="text-xs text-on-surface-variant mb-2">Your YES shares: <span id="userYesShares" class="font-mono text-primary">—</span></p>
          <input type="number" id="sellYesAmount" placeholder="Shares to sell" min="0.001" step="0.001"
                 class="w-full bg-surface-container-highest text-on-surface text-sm px-4 py-3 mb-2 border-none focus:outline-none focus:ring-1 focus:ring-error/20 placeholder:text-neutral-600" />
          <p class="text-[10px] text-on-surface-variant mb-1">Est. payout: <span id="sellYesPayout" class="font-mono text-primary">—</span></p>
          <p class="text-[10px] text-error mb-2 hidden" id="warnYesSell"></p>
          <button class="btn-sell-yes w-full bg-error/80 text-on-error font-bold py-3 hover:bg-error active:scale-95 transition-all" data-market-id="<%= market.id %>">
            Sell YES Shares
          </button>
        </div>
        <div class="bg-surface-container p-6 border-l-2 border-error/30">
          <h3 class="text-sm font-bold text-on-surface mb-4 uppercase tracking-wider">Sell NO</h3>
          <p class="text-xs text-on-surface-variant mb-2">Your NO shares: <span id="userNoShares" class="font-mono text-primary">—</span></p>
          <input type="number" id="sellNoAmount" placeholder="Shares to sell" min="0.001" step="0.001"
                 class="w-full bg-surface-container-highest text-on-surface text-sm px-4 py-3 mb-2 border-none focus:outline-none focus:ring-1 focus:ring-error/20 placeholder:text-neutral-600" />
          <p class="text-[10px] text-on-surface-variant mb-1">Est. payout: <span id="sellNoPayout" class="font-mono text-primary">—</span></p>
          <p class="text-[10px] text-error mb-2 hidden" id="warnNoSell"></p>
          <button class="btn-sell-no w-full bg-error/80 text-on-error font-bold py-3 hover:bg-error active:scale-95 transition-all" data-market-id="<%= market.id %>">
            Sell NO Shares
          </button>
        </div>
      </div>
    <% } else { %>
      <!-- Claim Winnings for resolved markets -->
      <div class="bg-surface-container p-6 mb-8 border-l-2 border-primary">
        <h3 class="text-sm font-bold text-on-surface mb-4 uppercase tracking-wider">Market Resolved</h3>
        <p class="text-on-surface-variant text-sm mb-4">This market has been resolved. If you hold winning shares, claim your winnings below.</p>
        <button class="btn-claim w-full bg-primary text-on-primary font-bold py-3 hover:bg-primary-container active:scale-95 transition-all" data-market-id="<%= market.id %>">
          Claim Winnings
        </button>
      </div>
    <% } %>

    <!-- Market Stats -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Volume</p>
        <p class="text-lg font-bold text-on-surface"><%= market.volume %></p>
      </div>
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Yes Price</p>
        <p class="text-lg font-bold text-primary"><%= market.yesPrice %>&cent;</p>
      </div>
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">No Price</p>
        <p class="text-lg font-bold text-on-surface"><%= market.noPrice %>&cent;</p>
      </div>
      <div>
        <p class="text-[10px] text-on-surface-variant uppercase tracking-widest mb-1">Traders</p>
        <p class="text-lg font-bold text-on-surface"><%= market.traders %></p>
      </div>
    </div>
  </div>
</section>
